# OS
.DS_Store
Thumbs.db

# Editors
*.swp
*.swo
*~
.vscode/
.idea/

# Skill workspaces (from skill-creator eval runs)
*-workspace/

# Agent plan files
plans/

# Plugin build output (repo-root dist/ created by build-plugin.sh)
dist/

# Synced skills directory (generated by build-plugin.sh --target claude-code)
# The source of truth is the category directories inside each plugin
# (e.g. plugins/tiger-marketing-skills/content-creation/)
plugins/*/skills/

# Vendor skills are managed via git submodules (plugins/*/vendor/*).
# Don't gitignore the vendor/ directory — it's tracked by git.
